# Copie para .env e preencha com valores reais (o .env NÃO é versionado).

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=bolao
DB_PASSWORD=changeme
DB_NAME=bolao_copa2026

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=defina-um-segredo-forte-aqui
JWT_EXPIRES=30d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# API de placares
SCORES_API_PRIMARY=https://worldcup26.ir/get/games
SCORES_API_FALLBACK=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
SCORES_SYNC_INTERVAL_MS=120000

# Sincroniza os jogos (fixtures) a cada login (intervalo mínimo em ms; 0 = sempre)
FIXTURES_LOGIN_SYNC_MIN_MS=60000

# Usuários de acesso (consumidos por: npm run seed:users)
# Telefone aceita qualquer formato; é normalizado para dígitos no login.
SEED_USER_NAME=Participante
SEED_USER_PHONE=
SEED_USER_PASSWORD=
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=
